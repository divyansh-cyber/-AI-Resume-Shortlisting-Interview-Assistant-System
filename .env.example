# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# Model for chat/reasoning
GEMINI_CHAT_MODEL=gemini-1.5-pro
# Model for embeddings (used in semantic similarity scoring)
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=resume_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resume_system

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# TTL in seconds for cached embeddings/scores (24h default)
REDIS_CACHE_TTL=86400

# ─── GitHub (Claim Verification) ──────────────────────────────────────────────
# Optional: increases GitHub API rate limit from 60 to 5000 req/hour
GITHUB_TOKEN=ghp_...

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
