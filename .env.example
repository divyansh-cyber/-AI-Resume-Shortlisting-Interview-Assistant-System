# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Grok (xAI) ──────────────────────────────────────────────────────────────
# Get your API key from https://console.x.ai/
GROK_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model for chat/reasoning (grok-3-mini is fast and cheap; grok-3 for higher quality)
GROK_CHAT_MODEL=grok-3-mini
# Model for embeddings
GROK_EMBEDDING_MODEL=v1

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=resume_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# DATABASE_URL is intentionally left unset when running via Docker Compose.
# docker-compose.yml overrides POSTGRES_HOST=postgres (the service name) and
# REDIS_HOST=redis so the app builds its connection from the individual parts above.
# Uncomment only if connecting to an external hosted DB.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resume_system

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# TTL in seconds for cached embeddings/scores (24h default)
REDIS_CACHE_TTL=86400

# ─── GitHub (Claim Verification) ──────────────────────────────────────────────
# Optional: increases GitHub API rate limit from 60 to 5000 req/hour
GITHUB_TOKEN=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
