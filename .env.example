# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Model for chat/reasoning (GPT-4o recommended, GPT-3.5-turbo for cost savings)
OPENAI_CHAT_MODEL=gpt-4o
# Model for embeddings (used in semantic similarity scoring)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=resume_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resume_system

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# TTL in seconds for cached embeddings/scores (24h default)
REDIS_CACHE_TTL=86400

# ─── GitHub (Claim Verification) ──────────────────────────────────────────────
# Optional: increases GitHub API rate limit from 60 to 5000 req/hour
GITHUB_TOKEN=ghp_...

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
